# Server-only (Vercel + local dev) — NEVER expose in client code
ANTHROPIC_API_KEY=

# Optional: cheaper/faster model (see console.anthropic.com for current ids)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Search providers (Claude synthesizes results into itinerary cards) ──

# Exa — open-ended discovery & activity recommendations (exa.ai)
# EXA_API_KEY=

# Expedia Rapid — live hotel rates (partner credentials from Expedia Group)
# EXPEDIA_RAPID_API_KEY=
# EXPEDIA_RAPID_SECRET=
# EXPEDIA_RAPID_ENV=test
# EXPEDIA_PROPERTY_IDS_ANTIGUA=19248
# EXPEDIA_PROPERTY_IDS_LAKE=

# Booking.com — Demand API (partner) or affiliate deep links
# BOOKING_DEMAND_API_KEY=
# BOOKING_AFFILIATE_ID=

# Tavily — legacy fallback if Exa is not set (tavily.com)
# TAVILY_API_KEY=

# Local dev fallback (vite only — prefer ANTHROPIC_API_KEY)
# VITE_ANTHROPIC_API_KEY=
